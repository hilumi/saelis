# Saelis environment variables — placeholders only. Copy to .env.local and fill in.
# Never commit .env.local or real secret values.

# Supabase project URL (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key (safe for the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key — SERVER ONLY. Never import into client components.
# Only needed for privileged operations (e.g. full account deletion).
SUPABASE_SECRET_KEY=

# OpenAI — SERVER ONLY. Never expose via NEXT_PUBLIC_*. Never commit real values.
# Required only when COMPANION_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional OpenAI provider tuning (defaults shown).
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=false

# Companion provider switch: "mock" (default, no external calls) or "openai".
COMPANION_PROVIDER=mock

# Canonical app URL, e.g. http://localhost:3000 in development
APP_URL=http://localhost:3000
