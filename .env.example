# Saelis environment variables — placeholders only. Copy to .env.local and fill in.
# Never commit .env.local or real secret values.

# Supabase project URL (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key (safe for the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key — SERVER ONLY. Never import into client components.
# Only needed for privileged operations (e.g. full account deletion).
SUPABASE_SECRET_KEY=

# OpenAI — SERVER ONLY. Never expose via NEXT_PUBLIC_*. Never commit real values.
# Required only when COMPANION_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional OpenAI provider tuning (defaults shown).
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=1600
OPENAI_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=false

# Companion provider switch: "mock" (default, no external calls) or "openai".
COMPANION_PROVIDER=mock

# Canonical app URL, e.g. http://localhost:3000 in development
APP_URL=http://localhost:3000

# Expo push access token — SERVER ONLY, OPTIONAL. Only needed if "Enhanced
# push security" is enabled for the EAS project; plain Expo push works
# without it. Never expose via NEXT_PUBLIC_* or EXPO_PUBLIC_*.
EXPO_ACCESS_TOKEN=

# --- Phase 6: admin analytics (see docs/admin-analytics.md) -----------------

# Authorizes POST /api/cron/analytics-rollup (Bearer token). SERVER ONLY.
# The rollup route is disabled (503) until this is set; nothing runs
# automatically — an external scheduler must call the route explicitly.
CRON_SECRET=

# Minimum cohort size for dimensional analytics breakdowns (default 5).
ANALYTICS_MIN_COHORT_SIZE=5

# Feature flags (server-side; NEVER a substitute for role authorization).
# Defaults: enabled, except exports which default OFF.
ADMIN_ANALYTICS_ENABLED=true
ANALYTICS_EVENT_INGESTION_ENABLED=true
ANALYTICS_ROLLUPS_ENABLED=true
ANALYTICS_EXPORTS_ENABLED=false
