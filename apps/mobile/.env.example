# Saelis mobile environment variables — placeholders only. Copy to .env and fill in.
# Only EXPO_PUBLIC_* values may appear here: they are inlined into the client
# bundle. NEVER add OpenAI or Supabase secret keys — those are server only.

# Supabase project URL (safe for the client)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key (safe for the client; protected by RLS)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Base URL of the Saelis web app / API (e.g. http://localhost:3000 in development)
EXPO_PUBLIC_SAELIS_API_URL=
